<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Dashboard QWeb Template
    ═══════════════════════════════════════════════════════════════ -->
     
    <!-- ═══════════════════════════════════════════════════════════════
         Menu Items
    ═══════════════════════════════════════════════════════════════ -->
    <menuitem
        id="hr_administration_root"
        name="HR Administration"
        sequence="50"
        web_icon="hr_administration,static/src/img/icon.png"
    />
    <!-- ═══════════════════════════════════════════════════════════════
         URL Actions
    ═══════════════════════════════════════════════════════════════ -->
    <record id="action_dashboard" model="ir.actions.act_url">
        <field name="name">HR Administration Dashboard</field>
        <field name="url">/hr-employee-admin</field>
        <field name="target">self</field>
    </record>

    <menuitem
        id="hr_administration_dashboard"
        name="HR Admin"
        action="hr_employee.action_view_employee_kanban_custom"
        sequence="1"
    />
        <!-- parent="hr_administration_root" -->


    <menuitem
        id="hr_administration_employees_menu"
        name="Employees"
        parent="hr_administration_root"
        sequence="2"
    />

    <menuitem
        id="hr_administration_leave_menu"
        name="Leave Management"
        parent="hr_administration_root"
        sequence="3"
    />

    <menuitem
        id="hr_administration_payroll_menu"
        name="Payroll"
        parent="hr_administration_root"
        sequence="4"
    />

    <menuitem
        id="hr_administration_reports_menu"
        name="Reports &amp; Analytics"
        parent="hr_administration_root"
        sequence="5"
    />

    

</odoo>
