                <xpath expr="//notebook[last()]">
                    <page string="Qualifications &amp; Skills" groups="hr.group_hr_user">
                        <group string="Extracted Qualification">
                            <field name="qualifications_text" readonly="0" widget="text" placeholder="Enter Qualification"/>
                        </group>
                        <group string="Extracted Skills">
                            <field name="skills_text" readonly="0" widget="text" placeholder="Enter Skills"/>
                        </group>
                        <group string="Extracted Experience">
                            <field name="experience_text" readonly="0" widget="text" placeholder="Enter experience"/>
                        </group>
                    </page>
                    <page string='Application Documents' groups="hr.group_hr_user">
                        <field name="applicant_documentation_checklist" options="{'no_open': True}" readonly="1">
                            <tree>
                                <field name="document_type" readonly="1"/>
                                <field name="applicant_submitted_document_file" string="Applicant Submitted document" readonly="1"/>
                                <field name="select" string="Is verified?" readonly="1"/>
