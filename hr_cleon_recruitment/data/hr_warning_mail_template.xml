<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for incident reference numbers -->
        <record id="seq_hr_warning" model="ir.sequence">
            <field name="name">HR Warning</field>
            <field name="code">hr.warning</field>
            <field name="prefix">INC-%(year)s-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ── Default template: notify stage approvers ─────────────────── -->
        <record id="mail_template_hr_warning_stage_notify" model="mail.template">
            <field name="name">HR Warning: Stage Approver Notification</field>
            <field name="model_id" ref="model_hr_warning"/>
            <field name="subject">Action Required: Incident {{ object.name }} — {{ object.stage_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) | safe }}</field>
            <field name="email_to">{{ ctx.get('approver_name', '') }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
    <h2 style="color: #e0245e;">Incident Notification — {{ object.stage_id.name }}</h2>

    <p>Dear {{ ctx.get('approver_name', 'Approver') }},</p>

    <p>
        The following incident has been moved to the <strong>{{ object.stage_id.name }}</strong> stage
        and requires your attention.
    </p>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold; width: 40%;">Reference</td>
            <td style="padding: 8px 12px;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Employee</td>
            <td style="padding: 8px 12px;">{{ object.employee_id.name }}</td>
        </tr>
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold;">Incident Type</td>
            <td style="padding: 8px 12px;">{{ object.incident_type | title }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Date of Incident</td>
            <td style="padding: 8px 12px;">{{ object.date_incident }}</td>
        </tr>
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold;">Current Stage</td>
            <td style="padding: 8px 12px;">{{ object.stage_id.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Investigator</td>
            <td style="padding: 8px 12px;">{{ object.investigator_id.name or 'Not assigned' }}</td>
        </tr>
    </table>

    <p><strong>Description:</strong></p>
    <p style="background: #f5f5f5; padding: 12px; border-left: 3px solid #e0245e;">
        {{ object.description or '—' }}
    </p>

    <p>
        <a href="/web#id={{ object.id }}&amp;model=hr.warning&amp;view_type=form"
           style="background: #e0245e; color: #fff; padding: 8px 16px;
                  border-radius: 4px; text-decoration: none; display: inline-block;">
            View Incident
        </a>
    </p>

    <p style="color: #999; font-size: 12px;">
        This is an automated message from {{ object.company_id.name }}.
    </p>
</div>
            ]]></field>
            <field name="auto_delete">True</field>
        </record>

        <!-- ── Template: notify the employee directly ────────────────────── -->
        <record id="mail_template_hr_warning_employee_notify" model="mail.template">
            <field name="name">HR Warning: Employee Notification</field>
            <field name="model_id" ref="model_hr_warning"/>
            <field name="subject">Notice Regarding Incident {{ object.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) | safe }}</field>
            <field name="email_to">{{ object.employee_id.work_email }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
    <h2 style="color: #e0245e;">Incident Notice — {{ object.name }}</h2>

    <p>Dear {{ object.employee_id.name }},</p>

    <p>
        We are writing to inform you of an incident that has been recorded against your employee profile.
    </p>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold; width: 40%;">Reference</td>
            <td style="padding: 8px 12px;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Date of Incident</td>
            <td style="padding: 8px 12px;">{{ object.date_incident }}</td>
        </tr>
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold;">Status</td>
            <td style="padding: 8px 12px;">{{ object.stage_id.name }}</td>
        </tr>
    </table>

    <p>
        Please contact your HR department for more information.
    </p>

    <p style="color: #999; font-size: 12px;">
        This is an automated message from {{ object.company_id.name }}.
    </p>
</div>
            ]]></field>
            <field name="auto_delete">True</field>
        </record>

    </data>
</odoo>
