<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_hr_offer" model="ir.sequence">
            <field name="name">HR offer sequence</field>
            <field name="code">hr.offer</field>
            <field name="prefix">OFFER-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ── Default template: notify stage approvers ─────────────────── -->
        <record id="mail_template_hr_offer_send_notify" model="mail.template">
            <field name="name">HR Offer: Offer send Notification</field>
            <field name="model_id" ref="model_hr_offer"/>
            <field name="subject">Offer Notification: {{ object.candidate_id.name }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email) | safe }}</field>
            <field name="email_to">{{ ctx.get('email_to', '') }}</field>
            <field name="body_html"><![CDATA[
                <div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
                    <h2 style="color: #e0245e;">Offer Notification — {{ object.candidate_id.partner_name }}</h2>

                    <p>Dear {{ ctx.get('candidate_name', 'Candidate') }},</p>

                    <p>
                        We are pleased to offer you the position of {{object.candidate_id.job_id.id }} at <strong>{{ user.company_id.name }}</strong>.
                    </p>
                    <p>
                        Kindly review the following information below.
                    </p>

                    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
                        <tr style="background: #f9f9f9;">
                            <td style="padding: 8px 12px; font-weight: bold; width: 40%;">Job Position</td>
                            <td style="padding: 8px 12px;">{{ object.applicant_id.job_id.name }}</td>
                        </tr>
                        <tr>
                            <td style="padding: 8px 12px; font-weight: bold;">Employee</td>
                            <td style="padding: 8px 12px;">{{ object.candidate_id.partner_name }}</td>
                        </tr>
                        <tr style="background: #f9f9f9;">
                            <td style="padding: 8px 12px; font-weight: bold;">Proposed Salary</td>
                            <td style="padding: 8px 12px;">{{ object.candidate_id.proposed_salary }}</td>
                        </tr>
                        <tr>
                            <td style="padding: 8px 12px; font-weight: bold;">Date of Incident</td>
                            <td style="padding: 8px 12px;">{{ object.date_incident }}</td>
                        </tr>
                        <tr style="background: #f9f9f9;">
                            <td style="padding: 8px 12px; font-weight: bold;">Expiry</td>
                            <td style="padding: 8px 12px;">{{ object.date_expiry }}</td>
                        </tr>
                        <tr>
                            <td style="padding: 8px 12px; font-weight: bold;">Contract Type</td>
                            <td style="padding: 8px 12px;">{{ object.job_id.contract_type_id or object.job_id.job_nature or object.candidate_id.job_id.contract_type_id or object.job_id.job_nature or 'Not assigned' }}</td>
                        </tr>
                    </table>

                    <p><strong>Offer terms:</strong></p>
                    <p style="background: #f5f5f5; padding: 12px; border-left: 3px solid #e0245e;">
                        {{ object.offer_terms or object.job_id.offer_terms }}
                    </p>

                    <p>
                        <!-- i want to loop object.offer_report_ids and build a download link for the users'
                        e.g f'/web/content/{attachment.id}?download=true', -->

                        <a href="/web/content/{{ attachment.id }}?download=true"
                        style="background: #e0245e; color: #fff; padding: 8px 16px;
                                border-radius: 4px; text-decoration: none; display: inline-block;">
                            View
                        </a>
                    </p>

                    <p style="color: #999; font-size: 12px;">
                        This is an automated message from {{ user.company_id.name }}.
                    </p>
                </div>
            ]]></field>
            <field name="auto_delete">True</field>
        </record>
    </data>
</odoo>
