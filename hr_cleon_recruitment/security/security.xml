<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_hr_Recruitment" model="ir.module.category">
            <field name="name">HR Recruitment</field>
            <field name="description">Manage employee  Recruitments</field>
            <field name="sequence">110</field>
        </record>

        <!-- HR Recruitment User: can create and view own incidents -->
        <record id="group_hr_Recruitment_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_hr_Recruitment"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_hr_Recruitment_officer" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_hr_Recruitment"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_Recruitment_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

