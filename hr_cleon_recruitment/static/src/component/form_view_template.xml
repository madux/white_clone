<templates xml:space="preserve">
       <t
            t-name="hr_cleon_recruitment.RecruitmentSidebarController"
            t-inherit="web.FormView"
            owl="1"
        >
            <!-- <xpath expr="//div[hasclass('o_form_view_container')]" position="inside"> -->
                <!-- <div class="o_form_view_container o_cc_layout_wrapper d-flex"> -->
            <xpath expr="//div[@t-ref='root']" position="before">
                <!-- <div class="dynamic-sidebar"> -->
                <aside class="dynamicsidebar">
                    <div class="sidebar-logo">
                        <div class="sidebar-logo-mark">C</div>
                        <span class="sidebar-logo-text">CleonHR</span>
                    </div>

                    <p class="sidebar-section-label">Recruiting</p>
                    <ul>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openJob">
                                <i class="sidebar-nav-icon fa fa-briefcase"></i>
                                Jobs
                                <span class="sidebar-badge">2</span>
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item active" t-on-click="openCandidate">
                                <i class="sidebar-nav-icon fa fa-users"></i>
                                Candidates
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openOffers">
                                <i class="sidebar-nav-icon fa fa-check-circle"></i>
                                Offers and Hired
                            </a>
                        </li>

                        <li>
                            <a class="sidebar-nav-item" t-on-click="openCandidate">
                                <i class="sidebar-nav-icon fa fa-store"></i>
                                Vendors
                            </a>
                        </li>
                    </ul>

                    <p class="sidebar-section-label">Workflow</p>
                    <ul>
                        
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openRecruitmentRequest">
                                <i class="sidebar-nav-icon fa fa-shirtsinbulk"></i>
                                Requisition
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openCandidate">
                                <i class="sidebar-nav-icon fa fa-clipboard-list"></i>
                                Tasks
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openDepartment">
                                <i class="sidebar-nav-icon fa fa-university"></i>
                                Department
                            </a>
                        </li>
                    </ul>
                    <p class="sidebar-section-label">Processes</p>
                    <ul style="margin-top: 12px;">
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openCBT">
                                <i class="sidebar-nav-icon fa fa-mortar-board"></i>
                                CBT Test
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openRecruitmentStages">
                                <i class="sidebar-nav-icon fa fa-line-chart"></i>
                                Stages
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openTalentMobility">
                                <i class="sidebar-nav-icon fa fa-grav"></i>
                                Talent Mobility
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openRecruitmentScoreSheet">
                                <i class="sidebar-nav-icon fa fa fa-table"></i>
                                Score Sheet
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openRecruitmentDocumentType">
                                <i class="sidebar-nav-icon fa fa-book"></i>
                                Documentation
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openApplicantImportWizard">
                                <i class="sidebar-nav-icon fa fa-download"></i>
                                Import Applicant
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openCandidate">
                                <i class="sidebar-nav-icon fa fa-layout-grid"></i>
                                ATS
                            </a>
                        </li>
                        <li>
                            <a class="sidebar-nav-item" t-on-click="openCandidate">
                                <i class="sidebar-nav-icon fa fa-settings"></i>
                                Settings
                            </a>
                        </li>
                    </ul>

                    <div style="flex:1;"></div>
                    <div class="sidebar-user">
                        <div class="sidebar-user-avatar">J</div>
                        <div class="sidebar-user-info">
                            <div class="sidebar-user-name">CleonHR</div>
                            <div class="sidebar-user-email">by Maachsolutions</div>
                        </div>
                    </div>
                </aside>
                <!-- </div> -->
            </xpath>

    </t>

</templates>


