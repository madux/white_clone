<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="hr_recruitment_base_job_form_view" model="ir.ui.view">
        <field name="name">hr.job.form</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='recruitment_page']/group" position="after">
                <group string="Additional Information">
                    <group>
                        <field name="job_stage" readonly="0" widget="badge"/>
                        <field name="priority" readonly="0" widget="priority"/>
                        <field name="deadline_date" readonly="0"/>
                        <field name="job_nature" readonly="0" widget="radio" options="{'horizontal': true}"/>
                        
                    </group>
                    <group>
                        <field name="opened_date" readonly="0" required="0"/>
                        <field name="deadline_date_char" readonly="1"/>
                        <field name="offer_report_ids" readonly="0" required="1" widget="many2many_tags"/>
                        <field name="hiring_team_ids" readonly="0" required="1" widget="many2many_tags"/>
                        <field name ="offer_terms" widget="html"/>
                    </group>
                </group>
            </xpath>
            <!-- <xpath expr="//field[@name='close_date']" position="before">
            </xpath> --> 
            <xpath expr="//notebook/page[last()]" position="after">
                <page string="Other Requirement">
                    <group string="req &amp; Qualification">
                        <field name="requirements" readonly="0" widget="text" placeholder="Enter Requirement"/>
                    </group>
                </page>
                <page string="Talent Mobility">
                    <group string="Talent">
                        <field name="talent_mobility_ids" readonly="0">
                            <tree string="">
                                <field name="employee_id" readonly="0"/>
                                <field name="matched_skill_ids" readonly="0" widget="many2many_tags"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="hr_applicant_recruitment_base_form_view" model="ir.ui.view">
        <field name="name">hr.applicant.recruitment.form</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_recruitment.hr_applicant_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='job_id']" position="after"> 
                <field name="applied_date" readonly="0" required="0"/>
                <field name="email_sent" readonly="1"/>
            </xpath>
             
        </field>
    </record>

    <record id="hr_applicant_cbt_recruitment_base_form_view" model="ir.ui.view">
        <field name="name">hr.applicant.recruitment.form</field>
        <field name="model">hr.applicant</field>
        <field name="inherit_id" ref="hr_cbt_portal_recruitment.hr_applicant_innherited_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='Other informations']" position="before">
                <page string="AI Extracted Skills, Education, Experiences">
                    <group string="Education &amp; Qualification">
                        <field name="qualifications_text" readonly="1" widget="text"/>
                    </group>
                    <group string="Experiences">
                        <field name="experience_text" readonly="1" widget="text"/>
                    </group>
                    <group string="Skills">
                        <field name="skills_text" readonly="1" widget="text"/>
                    </group>
                </page>
                
            </xpath>
            
           
        </field>
    </record>
    <record id="action_hr_add_job" model="ir.actions.act_window">
        <field name="name">Add Job</field>
        <field name="res_model">hr.job</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hr.view_hr_job_form"/>
        <field name="target">new</field>
        <!-- <field name="context">{'default_mode': 'select'}</field> -->
    </record>

    <record id="action_hr_survey_cbt_tree_action" model="ir.actions.act_window">
