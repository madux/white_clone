<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">

    <!-- =====================================================================
         COMPANY CALENDAR — Full UI Redesign
         Matches: sidebar nav, top action buttons, pink/magenta theme
    ====================================================================== -->

    <t
        t-name="hr_company_calendar.CustomCalendarController"
        t-inherit="calendar.AttendeeCalendarController"
        t-inherit-mode="extension"
        owl="1"
    >

        <!-- Buttons in the header row -->
        <xpath expr="//button[hasclass('oi-panel-right')]" position="before">
            <div class="flex-grow-1 d-none d-md-block"/>
            <button class="btn o_cc_btn_pink btn-sm" t-on-click="openGetStarted" type="button">
                <i class="fa fa-book"/> Get Started
            </button>
            <button class="btn o_cc_btn_pink_outline btn-sm" t-on-click="openGuidedTour" type="button">
                <i class="fa fa-magic"/> Guided Tour
            </button>
            <div class="btn-group">
                <button class="btn o_cc_btn_light btn-sm dropdown-toggle" data-bs-toggle="dropdown" type="button">
                    <i class="fa fa-user-circle-o"/> View as: <strong>Admin View</strong>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#">Admin View</a></li>
                    <li><a class="dropdown-item" href="#">Employee View</a></li>
                    <li><a class="dropdown-item" href="#">Manager View</a></li>
                </ul>
            </div>
            <button class="btn o_cc_btn_light btn-sm" t-on-click="exportCalendar" type="button">
                <i class="fa fa-upload"/> Export
            </button>
        </xpath>
 
        <!-- Sidebar injected directly into o_calendar_container, no wrapper div -->
        <xpath expr="//div[hasclass('o_calendar_container')]" position="inside">
            <div class="o_cc_admin_sidebar">
 
                <div class="o_cc_sidebar_header">
                    <span class="o_cc_header_dot"/>
                    <span class="o_cc_header_title">ADMIN CONTROLS</span>
                    <button class="btn btn-sm o_cc_collapse_btn" title="Collapse sidebar">
                        <i class="fa fa-th-large"/>
                    </button>
                </div>
 
                <nav class="o_cc_nav">
                    <a class="o_cc_nav_item o_cc_nav_active" t-on-click.prevent="openCalendarView">
                        <span class="o_cc_nav_icon"><i class="fa fa-calendar"/></span>
                        <span class="o_cc_nav_label">Calendar</span>
                        <i class="fa fa-chevron-right o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click.prevent="openActivitiesView">
                        <span class="o_cc_nav_icon"><i class="fa fa-comment-o"/></span>
                        <span class="o_cc_nav_label">Company Activities</span>
                        <i class="fa fa-chevron-right o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click.prevent="openApprovalsView">
                        <span class="o_cc_nav_icon"><i class="fa fa-check-square-o"/></span>
                        <span class="o_cc_nav_label">Approvals</span>
                        <span class="o_cc_nav_badge">2</span>
                        <i class="fa fa-chevron-right o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click.prevent="openCalendarSettings">
                        <span class="o_cc_nav_icon"><i class="fa fa-cog"/></span>
                        <span class="o_cc_nav_label">Calendar Settings</span>
                        <i class="fa fa-chevron-right o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click.prevent="openAuditLog">
                        <span class="o_cc_nav_icon"><i class="fa fa-file-text-o"/></span>
                        <span class="o_cc_nav_label">Audit Log</span>
                        <i class="fa fa-chevron-right o_cc_nav_arrow"/>
                    </a>
                </nav>
 
                <div class="o_cc_sidebar_footer">
                    <span class="o_cc_footer_label">Calendar Engine Status</span>
                    <div class="o_cc_footer_status">
                        <span class="o_cc_status_dot o_cc_status_green"/>
                        All integrations active
                    </div>
                </div>
 
            </div>
        </xpath>
 
    </t>
 
</templates>


