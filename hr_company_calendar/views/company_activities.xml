        <field name="state">code</field>
        <field name="code">
            action = env['company.calendar.dashboard'].action_load_data()
        </field>
    </record>


    <menuitem
        id="menu_company_activities"
        name="Company Activities"
        parent="calendar.mail_menu_calendar"
        action="action_load_company_calendar_data"
        sequence="8"
        />
    <!-- ─────────────────────────────────────────────
         Form View — Transient (wizard) model
         ───────────────────────────────────────────── -->
