<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="tax_status_resident" model="hr.tax.status">
        <field name="name">Resident Taxpayer</field>
        <field name="code">RESIDENT</field>
        <field name="description">
            Individual resident in Nigeria and subject to PAYE taxation.
        </field>
    </record>

    <record id="tax_status_non_resident" model="hr.tax.status">
        <field name="name">Non-Resident Taxpayer</field>
        <field name="code">NON_RESIDENT</field>
        <field name="description">
            Individual not resident in Nigeria for tax purposes.
        </field>
    </record>

    <record id="tax_status_employee_paye" model="hr.tax.status">
        <field name="name">Employee (PAYE)</field>
        <field name="code">PAYE</field>
        <field name="description">
            Employee subject to Pay-As-You-Earn deductions.
        </field>
    </record>

    <record id="tax_status_self_employed" model="hr.tax.status">
        <field name="name">Self Employed</field>
        <field name="code">SELF_EMPLOYED</field>
        <field name="description">
            Individual responsible for personal tax filing.
        </field>
    </record>

    <record id="tax_status_pensioner" model="hr.tax.status">
        <field name="name">Pensioner</field>
        <field name="code">PENSIONER</field>
        <field name="description">
            Retired individual receiving pension benefits.
        </field>
    </record>

    <record id="tax_status_expatriate" model="hr.tax.status">
        <field name="name">Expatriate Employee</field>
        <field name="code">EXPATRIATE</field>
        <field name="description">
            Foreign national employed in Nigeria.
        </field>
    </record>

    <record id="tax_status_sole_proprietor" model="hr.tax.status">
        <field name="name">Sole Proprietor</field>
        <field name="code">SOLE_PROP</field>
        <field name="description">
            Individual operating a business as sole owner.
        </field>
    </record>

    <record id="tax_status_partner" model="hr.tax.status">
        <field name="name">Partner in Partnership</field>
        <field name="code">PARTNER</field>
        <field name="description">
            Individual participating in a partnership business.
        </field>
    </record>

</odoo>