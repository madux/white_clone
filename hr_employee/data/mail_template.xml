<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for incident reference numbers -->
        <record id="seq_core_announcement" model="ir.sequence">
            <field name="name">HR core announcement</field>
            <field name="code">hr.core_announcement</field>
            <field name="prefix">ANN-0001-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- ── Default template: notify stage approvers ─────────────────── -->
        <record id="mail_template_core_announcement_notify" model="mail.template">
            <field name="name">HR announcement: Announcement Notification</field>
            <field name="model_id" ref="model_hr_core_announcement"/>
            <field name="subject">Announcement: {{ object.announcement_title }}</field>
            <field name="email_from">{{ user.email | safe }}</field>
            <field name="email_to">{{ ctx.get('approver_name', '') }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; font-size: 14px; color: #333;">
    <h2 style="color: #e0245e;">Announcement Notification — {{ object.announcement_type }}</h2>

    <p>Dear Team</p>

    <p>
        The following is the reason for this notification. Priority is <strong>{{ object.priority_level }}</strong> 
        and requires your attention.
    </p>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold; width: 40%;">Reference</td>
            <td style="padding: 8px 12px;">{{ object.announcement_title }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Employee</td>
            <td style="padding: 8px 12px;">{{ object.write_uid.name }}</td>
        </tr>
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold;">Announcement Type</td>
            <td style="padding: 8px 12px;">{{ object.announcement_type }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Date of Expiry</td>
            <td style="padding: 8px 12px;">{{ object.expiry_date }}</td>
        </tr>
        <tr style="background: #f9f9f9;">
            <td style="padding: 8px 12px; font-weight: bold;">Priority level</td>
            <td style="padding: 8px 12px;">{{ object.priority_level }}</td>
        </tr>
        <tr>
            <td style="padding: 8px 12px; font-weight: bold;">Target audience</td>
            <td style="padding: 8px 12px;">{{ object.target_audience }}</td>
        </tr>
    </table>

    <p><strong>Description:</strong></p>
    <p style="background: #f5f5f5; padding: 12px; border-left: 3px solid #e0245e;">
        {{ object.announcement_body or '—' }}
    </p>

    <p>
        <a href="/web#id={{ object.id }}&amp;model=hr.core_announcement&amp;view_type=form"
           style="background: #e0245e; color: #fff; padding: 8px 16px;
                  border-radius: 4px; text-decoration: none; display: inline-block;">
            View Announcement
        </a>
    </p>

    <p style="color: #999; font-size: 12px;">
        This is an automated message from {{ object.user_id.company_id.name }}.
    </p>
</div>
            ]]></field>
            <field name="auto_delete">True</field>
        </record>

        
    </data>
</odoo>
