<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_hr_employee_core" model="ir.module.category">
            <field name="name">HR Core</field>
            <field name="description">Manage employee features</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_hr_employee_core_user" model="res.groups">
            <field name="name">Employee User</field>
            <field name="category_id" ref="module_hr_employee_core"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- HR Warning Officer: can process incidents and move stages -->
        <record id="group_hr_employee_core_manager" model="res.groups">
            <field name="name">HR Manager</field>
            <field name="category_id" ref="module_hr_employee_core"/>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <record id="group_hr_employee_core_superuser" model="res.groups">
            <field name="name">HR Super User</field>
            <field name="category_id" ref="module_hr_employee_core"/>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
        </record>

        <!-- HR Warning Manager: full access including configuration -->
        <!-- <record id="group_hr_warning_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_hr_warning"/>
            <field name="implied_ids" eval="[(4, ref('group_hr_warning_officer'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>-->

        <record id="hr_announcement_admin_user_see_all" model="ir.rule">
            <field name="name">Admin See all announcement</field>
            <field name="model_id" ref="hr_employee.model_hr_core_announcement"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr_employee.group_hr_employee_core_superuser')),(4, ref('hr_employee.group_hr_employee_core_manager')), (4, ref('base.user_root'))]"/>
        </record>

        <record id="hr_announcement_user_see_related_record" model="ir.rule">
            <field name="name">user see related hr announcement records</field>
            <field name="model_id" ref="hr_employee.model_hr_core_announcement"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|',
            ('create_uid.id', '=', user.id),
            ('receipient_ids.id', 'in', [user.id])
            ]</field>
            <field name="groups" eval="[(4, ref('hr_employee.group_hr_employee_core_user')), (4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
