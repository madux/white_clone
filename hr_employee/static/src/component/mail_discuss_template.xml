<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="hr_employee.DiscussSidebar" t-inherit="mail.DiscussSidebar" t-inherit-mode="extension">
        <!-- <xpath expr="//div[@t-ref='root']" position="before"> -->
        <xpath expr="//div[hasclass('o-mail-DiscussSidebar')]"
               position="before">
            <div class="o_cc_admin_sidebar">
 
                <div class="o_cc_sidebar_header">
                    <span class="o_cc_header_dot"/>
                    <span class="o_cc_header_title">Staff Directory</span>
                    <button class="btn btn-sm o_cc_collapse_btn" title="Collapse sidebar">
                        <i class="fa fa-th-large"/>
                    </button>
                </div>
 
                <nav class="o_cc_nav">
                    <a class="o_cc_nav_item o_cc_nav_active" t-on-click="openRecord">
                        <span class="o_cc_nav_icon"><i class="fa fa-calendar"/></span>
                        <span class="o_cc_nav_label">Dashboard</span>
                        <span class="o_cc_nav_badge">2</span>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openCustomHearings">
                        <span class="o_cc_nav_icon"><i class="fa fa-users"/></span>
                        <span class="o_cc_nav_label">Employee Profiles</span>
                        <i class="fa fa-users o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" href="/organisation-chart">
                        <span class="o_cc_nav_icon"><i class="fa fa-building"/></span>
                        <span class="o_cc_nav_label">Organisation Chart</span>
                        <span class="o_cc_nav_badge">2</span>
                        <i class="fa fa-building o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openMessage">
                        <span class="o_cc_nav_icon"><i class="fa fa-comments green_badge_status"/></span>
                        <span class="o_cc_nav_label">Messages</span>
                        <i class="fa fa-comments o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openMeasures">
                        <span class="o_cc_nav_icon"><i class="fa fa-calendar"/></span>
                        <span class="o_cc_nav_label">Meeting</span>
                        <i class="fa fa-calendar o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openRecord">
                    <!-- <a class="o_cc_nav_item" href="/incident-reporting"> -->
                        <span class="o_cc_nav_icon"><i class="fa fa-plane green_badge_status"/></span>
                        <span class="o_cc_nav_label">Vacations</span>
                        <i class="fa fa-plane o_cc_nav_arrow"/>
                    </a>
                    
                    <a class="o_cc_nav_item" t-on-click="openCaseType">
                        <span class="o_cc_nav_icon"><i class="fa fa-building-o"/></span>
                        <span class="o_cc_nav_label">Departments</span>
                        <i class="fa fa-building-o o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openCustomAppeal">
                        <span class="o_cc_nav_icon"><i class="fa fa-frown-o yellow_badge_status"/></span>
                        <span class="o_cc_nav_label">Disciplinary</span>
                        <i class="fa fa-frown-o o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" href="/incident-reporting">
                        <span class="o_cc_nav_icon"><i class="fa fa-id-badge red_badge_status"/></span>
                        <span class="o_cc_nav_label">Positions</span>
                        <i class="fa fa-id-badge o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openRecord">
                    <!-- <a class="o_cc_nav_item" href="/incident-reporting"> -->
                        <span class="o_cc_nav_icon"><i class="fa fa-thumb-tack yellow_badge_status"/></span>
                        <span class="o_cc_nav_label">Task &amp; Assignments</span>
                        <i class="fa fa-thumb-tack o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openRecord">
                    <!-- <a class="o_cc_nav_item" href="/incident-reporting"> -->
                        <span class="o_cc_nav_icon"><i class="fa fa-star green_badge_status"/></span>
                        <span class="o_cc_nav_label">Active Staff</span>
                        <i class="fa fa-star employee_status o_cc_nav_arrow"/>
                    </a>
                    <a class="o_cc_nav_item" t-on-click="openRecord">
                    <!-- <a class="o_cc_nav_item" href="/incident-reporting"> -->
                        <span class="o_cc_nav_icon"><i class="fa fa-ban red_badge_status"/></span>
                        <span class="o_cc_nav_label">Terminated Staff</span>
                        <i class="fa fa-ban o_cc_nav_arrow"/>
                    </a>
                    
                    <a class="o_cc_nav_item" t-on-click="openInvestigations">
                        <span class="o_cc_nav_icon"><i class="fa fa-settings"/></span>
                        <span class="o_cc_nav_label">Setting</span>
                        <i class="fa fa-settings o_cc_nav_arrow"/>
                    </a>

                </nav>
 
                <div class="o_cc_sidebar_footer">
                    <span class="o_cc_footer_label">Solution By MaachSoftware</span>
                    <div class="o_cc_footer_status">
                        <span class="o_cc_status_dot o_cc_status_green"/>
                        All integrations active
                    </div>
                </div>
 
            </div>
        </xpath>
    </t> 
</templates>