<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_employee.OrganisationListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="primary">
        
        <xpath expr="//div[@t-ref='root']" position="before">
            <div class="o_cc_admin_sidebar">
 
                <div class="organi_o_cc_sidebar_header">
                    <!-- <span class="o_cc_header_dot"/> -->
                    <span class="organi_o_cc_header_title">Employee<br/>Management</span>
                    <button class="btn btn-sm organi_o_cc_collapse_btn" title="Collapse sidebar">
                        <i class="fa fa-th-large"/>
                    </button>
                </div>
 
                <nav class="organi_o_cc_nav" id="primaryNav">
                    <!-- Overview -->
                    <div class="organi_o_cc_nav_item psb-active" data-item="overview">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-dashboard"/>
                        </span>
                        <span class="o_cc_nav_label">Overview</span>
                    </div>
                    <t t-foreach="sidebarState.menus"
                        t-as="menu"
                        t-key="menu.id">
                        <div class="organi_o_cc_nav_item" t-on-click="() => this.openMenu(menu)">
                            <span class="organi_o_cc_nav_icon"><i t-att-class="menu.icon_class"/></span>
                            <span class="organi_o_cc_nav_label"><t t-esc="menu.name"/></span>
                            <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                        </div>

                        <!-- <a class="organi_o_cc_nav_item"
                            t-on-click="() => this.openMenu(menu)">
                            <span class="organi_o_cc_nav_icon">
                                <i t-att-class="menu.icon_class"/>
                            </span>
                            <span class="o_cc_nav_label">
                                <t t-esc="menu.name"/>
                            </span>
                            <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>

                        </a> -->

                    </t>

                </nav>
 
                <div class="o_cc_sidebar_footer">
                    <span class="o_cc_footer_label">Solution By MaachSoft</span>
                    <div class="o_cc_footer_status">
                        <span class="o_cc_status_dot o_cc_status_green"/>
                        All integrations active
                    </div>
                </div>
            </div>
        </xpath>
    </t> 
</templates>
 