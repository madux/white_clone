<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hr_employee.OrganisationListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="primary">
        
        <xpath expr="//div[@t-ref='root']" position="before">
            <div class="o_cc_admin_sidebar">
 
                <div class="organi_o_cc_sidebar_header">
                    <!-- <span class="o_cc_header_dot"/> -->
                    <span class="organi_o_cc_header_title">Employee<br/>Management</span>
                    <button class="btn btn-sm organi_o_cc_collapse_btn" title="Collapse sidebar">
                        <i class="fa fa-th-large"/>
                    </button>
                </div>
 
                <nav class="organi_o_cc_nav" id="primaryNav">

                    <!-- Overview -->
                    <a class="organi_o_cc_nav_item" t-on-click="openRecord">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-dashboard"/>
                        </span>
                        <span class="o_cc_nav_label">Overview</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Organisation -->
                    <a class="organi_o_cc_nav_item" t-on-click="openCustomHearings">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-building"/>
                        </span>
                        <span class="organi_o_cc_nav_label">Organisation</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Organisation Chart -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-sitemap"/>
                        </span>
                        <span class="o_cc_nav_label">Organisation Chart</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Onboarding -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-user-plus"/>
                        </span>
                        <span class="o_cc_nav_label">Onboarding</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Offboarding -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-user-times"/>
                        </span>
                        <span class="o_cc_nav_label">Offboarding</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Documentation -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-file-text-o"/>
                        </span>
                        <span class="o_cc_nav_label">Documentation</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Verification -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-check-circle"/>
                        </span>
                        <span class="o_cc_nav_label">Verification</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Workforce -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-users"/>
                        </span>
                        <span class="o_cc_nav_label">Workforce</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Compensation -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-money"/>
                        </span>
                        <span class="o_cc_nav_label">Compensation</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Benefits -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-gift"/>
                        </span>
                        <span class="o_cc_nav_label">Benefits</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Performance & Dev -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-line-chart"/>
                        </span>
                        <span class="o_cc_nav_label">Performance &amp; Dev</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                    <!-- Staff Engagement -->
                    <a class="organi_o_cc_nav_item" t-on-click="openMeasures">
                        <span class="organi_o_cc_nav_icon">
                            <i class="fa fa-comments"/>
                        </span>
                        <span class="o_cc_nav_label">Staff Engagement</span>
                        <i class="fa fa-chevron-right organi_o_cc_nav_arrow"/>
                    </a>

                </nav>
 
                <div class="o_cc_sidebar_footer">
                    <span class="o_cc_footer_label">Solution By MaachSoft</span>
                    <div class="o_cc_footer_status">
                        <span class="o_cc_status_dot o_cc_status_green"/>
                        All integrations active
                    </div>
                </div>
            </div>
        </xpath>
    </t> 
</templates>
 