<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_multi_branch_tree" model="ir.ui.view">
        <field name="name">multi.branch.employee.tree</field>
        <field name="model">multi.branch</field>
        <field name="arch" type="xml">
            <tree string="Branch" js_class="organisation_list">
                <field name="name" string="Name"/>
                <field name="code" string="Code"/>
                <field name="street" string="Address"/>
                <field name="city" string="City"/>
                <field name="country_id" string="Country"/>
                <field name="employee_count" string="Employees"/>
                <field name="company_id" string="Company"/>
            </tree>
        </field>
    </record>
    <record id="view_hr_core_multi_branch_form" model="ir.ui.view">
        <field name="name">multi.branch.form</field>
        <field name="model">multi.branch</field>
        <field name="arch" type="xml">
            <form string="Branch Information" >
                <button name="action_view_employees"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-users">

                    <field name="employee_count"
                        widget="statinfo"
                        string="Employees"/>
                </button>
                <sheet id="view-org-setup">

                    <div class="os-modal-overlay" id="branchEditModal">
                        <div class="os-modal">
                            <div class="os-modal-header">
                                <h3>Branch</h3>
                            </div>
                            <div class="os-modal-body">
                                <!-- <div class="os-form-group">
                                    <label for="name">Branch Name</label>
                                    <field name="name" class="os-input"/>
                                </div>
                                <div class="os-form-row">
                                    <div class="os-form-group">
                                    <label for="code">Code</label>
                                        <field name="code" nolabel="1"/>
                                    </div>
                                    <div class="os-form-group p-2">
                                        <label for="employee_count" class="p-2">Employees</label>
                                        <field name="employee_count" nolabel="1"/>

                                    </div>
                                </div> -->
                                <group>
                                    <field name="name" string="Branch Name"/>
                                    <field name="code"/>
                                </group>
                                <group>
                                    <field name="employee_count" readonly="0"/>
                                </group>
                                <group cols="4">
                                    <group>
                                        <field name="company_id"/>
                                        <field name="telephone_no"/>
                                    </group>
                                    <group>
                                        <label for="street" string="Address"/>
                                        <div>
                                            <div class="o_address_format" name="div_address">
                                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                                <field name="city" placeholder="City" class="o_address_city"/>
                                                <field name="state_id" class="o_address_state" placeholder="State" options='{"no_open": True}' context="{'country_id': country_id, 'zip': zip}"/>
                                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                                <field name="country_id" placeholder="Country" class="o_address_country" options='{"no_open": True, "no_create": True}'/>
                                                
                                            </div>
                                        </div>

                                    </group>
                                </group>
                                <!-- <div class="os-form-group">
                                    <label for="street">Address</label>
                                    <field name="street" nolabel="1" widget="text" class="os-input os-textarea" colspan="2"/>
                                </div>
                                <div class="os-form-group">
                                    <label for="active">Status</label>
                                    <field name="active" nolabel="1"/>
                                </div> -->
                            </div> 
                        </div>
                    </div>
 
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_core_multi_branch" model="ir.actions.act_window">
        <field name="name">Branch</field>
        <field name="res_model">multi.branch</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_multi_branch_tree"/>
         <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {
                'view_mode': 'tree',
                'view_id': ref('view_multi_branch_tree'),
            }),
            (0, 0, {
                'view_mode': 'form',
                'view_id': ref('hr_employee.view_hr_core_multi_branch_form'),
            }),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No recorded yet.
            </p>
            <p>Create a New record.</p>
        </field>
    </record>
    
</odoo>
