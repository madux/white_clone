<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_core_department_tree" model="ir.ui.view">
        <field name="name">hr.core_department.tree</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <tree string="Department" js_class="organisation_list">
                <field name="name"/>
                <!-- <field name="code"/> -->
                <field name="manager_id"/>
                <!-- <field name="company_id"/> -->
            </tree>
        </field>
    </record>

    <record id="hr_department_form_view" model="ir.ui.view">
        <field name="name">hr.department.form</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <group string="Department" class="measure-type-section">
                        <div class="measure-option-title-default" colspan="2">
                            Department Name
                            <field name="name" required="1" nolabel="1" placeholder="Technology"/>
                        </div>
                        <div class="measure-option-title-default" colspan="2">
                            Manager
                            <field name="manager_id" nolabel="1" required="1"/>
                        </div> 
                    </group> 
                     
                    <group>
                        <group>
                            <field name="company_id" nolabel="0"/>
                            <field name="contact_person" nolabel="0"/>
                            <field name="contact_person_phone" nolabel="0"/>
                            <field name="contact_person_mail" nolabel="0"/>
                        </group>
                        <group>
                            <field name="total_employee" nolabel="0"/>
                            <field name="expected_employee" nolabel="0"/>
                            <field name="new_hired_employee" nolabel="0" readonly="1"/>
                            <field name="absence_of_today" nolabel="0"/>
                            <field name="active" widget ="boolean_toogle" nolabel="0"/>
                        </group>
                    </group>
                    <!-- <group string="Position/Designations">
                        <div class="pay-status-box" colspan="2">
                            <field name="job_ids" nolabel="1" widget="many2many_tags" readonly="1" colspan="2" placeholder="Please start typing ...."/>
                        </div>
                    </group> -->
                    <group string="Members">
                        <div class="pay-status-box" colspan="2">
                            <field name="member_ids" nolabel="1" readonly="1" colspan="2"/>
                        </div>
                    </group>
                    <group string="Description">
                        <div class="pay-status-box" colspan="2">
                            <field name="note" nolabel="1" widget="text" readonly="0" colspan="2" placeholder="Please start typing ...."/>
                        </div>
                    </group>

                       
                    <group string=" *">
                        <div class="pay-status-box" colspan="2">
                            <div class="pay-status-title">
                            </div>
                            <div class="pay-status-warning">
                                <span class="pay-status-warning-icon">⚠</span>
                                <field name="child_ids" widget="many2many_tags" nolabel="1" colspan="2" options="{'no_open': true, 'no_create': true}"/>
                            </div>
                        </div>
                    </group>

                    <group string="Plannings">
                        <div class="pay-status-box" colspan="2">
                            <div class="pay-status-title">
                            </div>
                            <div class="pay-status-warning">
                                <span class="pay-status-warning-icon">⚠</span>
                                <field name="plan_ids" widget="many2many_tags" nolabel="1" colspan="2" options="{'no_open': true, 'no_create': true}"/>
                            </div>
                        </div>
                    </group>
                     

                    <group string="Attachment">
                        <field name="department_attachment_ids"
                        widget="many2many_binary"
                        nolabel="1"
                        string="Attachments" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="hr_department_kanban_view" model="ir.ui.view">
        <field name="name">hr.department.kanban</field>
        <field name="model">hr.department</field>
        <field name="arch" type="xml">
            <kanban create="0">
                <field name="id"/>
                <field name="name"/> 
                <templates>
                    <!-- <t t-name="kanban-box"> -->
                    <t t-name="kanban-box">
                        <!-- <div class="oe_kanban_card"> -->
                        <div class="du-dept-card" data-code="ENG" data-budget="2400000" data-target="48">
                            <div class="du-card-header-row">
                                <span class="du-emoji-icon">&#x1F4BB;</span>
                                <span class="du-staff-badge"><field name="total_employee" nolabel="1" readonly="0"/> staff</span>
                            </div>
                            <h3 class="du-dept-title"><field name="name" nolabel="1"/></h3>
                            <p class="du-dept-meta">Head: <span class="du-meta-highlight"><field name="manager_id" nolabel="1" readonly="0"/></span></p>
                            <p class="du-dept-location"><i class="fa fa-map"></i> <field name="company_id" nolabel="1" readonly="0"/></p>
                            <div class="du-metric-row">
                                <div class="du-metric-block">
                                <span class="du-metric-val du-text-pink"><field name="department_budget" nolabel="1" readonly="0"/></span>
                                <span class="du-metric-lbl">Budget</span>
                                </div>
                                <div class="du-metric-block">
                                <span class="du-metric-val du-text-pink"><field name="expected_employee" nolabel="1" readonly="0"/></span>
                                <span class="du-metric-lbl">Open Roles</span>
                                </div>
                                <div class="du-metric-block">
                                <span class="du-metric-val du-text-muted"><field name="total_employee" nolabel="1" readonly="0"/></span>
                                <span class="du-metric-lbl">Headcount</span>
                                </div>
                            </div>
                            <div class="du-progress-container">
                                <div class="du-progress-labels">
                                <span>Budget used</span>
                                <span>78%</span>
                                </div>
                                <div class="du-progress-bar-bg">
                                <div class="du-progress-bar-fill du-fill-orange" style="width: 78%;"></div>
                                </div>
                            </div>
                            <div class="du-card-actions-row">
                                <button name="action_view_record" type="object" class="du-action-btn du-text-dark">View Detail</button>
                                <button name="action_view_record" type="object" class="du-action-btn du-text-muted" data-action="edit-dept">Edit</button>
                                <button name="unlink" type="object" confirm="Do you want to Delete?" class="du-action-btn du-text-red">Delete</button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_core_department" model="ir.actions.act_window">
        <field name="name">Department</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="view_id" ref="hr_department_kanban_view"/>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {
                'view_mode': 'tree',
                'view_id': ref('view_core_department_tree'),
            }),
            (0, 0, {
                'view_mode': 'form',
                'view_id': ref('hr_employee.hr_department_form_view'),
            }),
            (0, 0, {
                'view_mode': 'kanban',
                'view_id': ref('hr_employee.hr_department_kanban_view'),
            }),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No recorded yet.
            </p>
            <p>Create a New record.</p>
        </field>
    </record>
</odoo>
