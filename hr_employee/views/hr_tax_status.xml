<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_hr_tax_status_tree" model="ir.ui.view">
        <field name="name">hr.tax.status.tree</field>
        <field name="model">hr.tax.status</field>
        <field name="arch" type="xml">
            <tree js_class="organisation_list">
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_hr_tax_status_form" model="ir.ui.view">
        <field name="name">hr.tax.status.form</field>
        <field name="model">hr.tax.status</field>
        <field name="arch" type="xml">
            <form string="Tax Status">

                <sheet>

                    <!-- HEADER CARD -->

                    <div class="p-4 mb-4 bg-primary-subtle rounded shadow-sm">

                        <div class="d-flex align-items-center">

                            <div class="me-3">
                                <i class="fa fa-university fa-3x text-primary"/>
                            </div>

                            <div class="oe_title">

                                <label for="name"/>

                                <h1>
                                    <field name="name"
                                           placeholder="Tax Status"/>
                                </h1>

                                <div class="text-muted">
                                    Configure tax status classifications for employees.
                                </div>

                            </div>

                        </div>

                    </div>

                    <group>

                        <group string="Basic Information">
 
                            <field name="code"/> 
                            <field name="active"/> 
                        </group>

                        <group string="Details">

                            <field name="description"/>
                            <field name="country_ids" widget="many2many_tags" required="1" readonly="0" options="{'no_open': true, 'no_create': true}" invisible="0"/>
                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>

    <!-- SEARCH VIEW -->

    <record id="view_hr_tax_status_search" model="ir.ui.view">
        <field name="name">hr.tax.status.search</field>
        <field name="model">hr.tax.status</field>
        <field name="arch" type="xml">

            <search>

                <field name="name"/>

                <field name="code"/>

                <separator/>

                <filter string="Active"
                        name="active"
                        domain="[('active','=',True)]"/>

                <filter string="Inactive"
                        name="inactive"
                        domain="[('active','=',False)]"/>

            </search>

        </field>
    </record>

    <!-- ACTION -->

    <record id="action_hr_tax_status" model="ir.actions.act_window">
        <field name="name">Tax Status</field>
        <field name="res_model">hr.tax.status</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hr_tax_status_search"/>
    </record>

    <menuitem
        id="menu_hr_tax_status"
        name="💰 Tax Status"
        parent="hr_employee.menu_hr_core_organisation_setup"
        action="action_hr_tax_status"
        sequence="70"
        groups="base.group_system,hr_employee.group_hr_employee_core_superuser,hr_employee.group_hr_employee_core_superuser"/>

</odoo>