<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="hmo_hr_grade_1" model="hr.grade">
            <field name="name">📝 Grade 1</field>
        </record>
        <record id="hmo_hr_grade_2" model="hr.grade">
            <field name="name">📝 Grade 2</field>
        </record>
        <record id="hmo_hr_grade_3" model="hr.grade">
            <field name="name">📝 Grade 3</field>
        </record>
        <record id="hmo_hr_grade_4" model="hr.grade">
            <field name="name">📝 Grade 4</field>
        </record>
        <record id="hmo_hr_grade_5" model="hr.grade">
            <field name="name">📝 Grade 5</field>
        </record>
        <record id="hmo_hr_grade_6" model="hr.grade">
            <field name="name">📝 Grade 6</field>
        </record>
        <record id="hmo_setting_1" model="hmo.setting">
            <field name="name">📝 Junior level Eligibility</field>
            <field name="description">Setup For Grade 1 Eligibility</field>
            <field name="sequence">1</field>
            <field name="eligibilty_ids" eval="[(6,0,[ref('hmo_hr_grade_1'), ref('hmo_hr_grade_2')])]"/>

        </record>
        <record id="hmo_setting_2" model="hmo.setting">
            <field name="name">📝 Middle Level Eligibility</field>
            <field name="description">Setup For Grade 3, 4 Eligibility</field>
            <field name="sequence">2</field>
            <field name="eligibilty_ids" eval="[(6,0,[ref('hmo_hr_grade_3'), ref('hmo_hr_grade_4')])]"/>

        </record>
        <record id="hmo_setting_3" model="hmo.setting">
            <field name="name">📝 Senior Grade Eligibility</field>
            <field name="description">Setup For Grade 4, 5, 6 Eligibility</field>
            <field name="sequence">3</field>
            <field name="eligibilty_ids" eval="[(6,0,[ref('hmo_hr_grade_5'), ref('hmo_hr_grade_6')])]"/>
        </record> 
    </data>
</odoo>