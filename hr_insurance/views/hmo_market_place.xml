    <!-- ══════════════════════════════════════════════════
         MENU
    ══════════════════════════════════════════════════ -->

    <menuitem
        id="menu_hmo_market_place"
        name="HMO Market Place"
        action="action_hmo_marketplace"
        sequence="40"
        groups="base.group_system"
        />
    

</odoo>
