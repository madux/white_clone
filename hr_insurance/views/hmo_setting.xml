                    </div> -->
                </div>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         ACTION
    ══════════════════════════════════════════════════ -->
    <record id="action_hmo_setting" model="ir.actions.act_window">
        <field name="name">HMO Setting</field>
        <field name="res_model">hmo.setting</field>
        <field name="view_mode">form</field>
        <field name="search_view_id" ref="view_hmo_setting_search"/>
        <field name="context">{}</field>
        <field name="target">new</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No record found
            </p>
            <p>
                Create a new Setting
            </p>
        </field>
    </record> 

    <record id="action_hmo_tree_Setting" model="ir.actions.act_window">
        <field name="name">HMO Setting</field>
        <field name="res_model">hmo.setting</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_hmo_setting_tree"/>
        <field name="context">{}</field>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No record found
            </p>
            <p>
                Create a new Setting
            </p>
        </field>
    </record> 

    <!-- ══════════════════════════════════════════════════
         MENU
    ══════════════════════════════════════════════════ -->

    <menuitem
        id="menu_hmo_hmo_setting"
        name="HMO Setting"
        action="action_hmo_tree_Setting"
        sequence="50"
        parent="hr_insurance.menu_hmo_configuration"
        />

</odoo>
