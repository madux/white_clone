<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <!-- ══════════════════════════════════════════════════
         TREE / LIST VIEW
    ══════════════════════════════════════════════════ -->
    <record id="view_hmo_setting_tree" model="ir.ui.view">
        <field name="name">hmo.setting.tree</field>
        <field name="model">hmo.setting</field>
        <field name="arch" type="xml">
            <tree
                string="Setting"
                multi_edit="1"
                class="o_qms_list">

                <field name="name" string="Name" optional="show"/>
                <field name="sequence" optional="show"/>
                <!-- <button name="set_done"
                                type="object"
                                string="Mark as done"
                                class="btn-sm btn-success"/> -->
            </tree>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════ -->
    <record id="view_hmo_setting_search" model="ir.ui.view">
        <field name="name">hmo.setting.search</field>
        <field name="model">hmo.setting</field>
        <field name="arch" type="xml">
            <search string="Setting search">
                <field name="name" string="Setting "/>
                <field name="sequence"/>
                <separator/>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════
         FORM VIEW  — Modern Card-based UI
    ══════════════════════════════════════════════════ -->
    <record id="view_hmo_setting_form" model="ir.ui.view">
        <field name="name">hmo.setting.form</field>
        <field name="model">hmo.setting</field>
        <field name="arch" type="xml">
            <form string="HMO Setting" class="o_qms_form">
                <!-- ══ STATUS BAR ══ -->
                <div class="qms-card">
                    <div class="qms-card-header">
                        <div class="qms-card-icon">
                            <svg viewBox="0 0 24 24"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        </div>
                        <span class="qms-card-title">Setting Details</span>
                    </div>
                    <div class="ash-card-body">
                        <group>
                            <group col="4">
                                <field name="name" class="pink-text" readonly="0"/> 
                            </group>

                            <group>
                                <field name="sequence" required="1"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="eligibilty_ids" widget="many2many_tags"/>
                                <field name="hmo_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                    </div>
                    <!-- <div class="ash-card-body text-sm">
                        <span class="qms-card-title">Eligibility</span>
                        <notebook> 
                            <page string="📋 Eligibility" name="eligibilty_ids">
                                <div class="qms-card" style="margin-bottom:0;">
