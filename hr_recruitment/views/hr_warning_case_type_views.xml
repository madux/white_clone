<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_warning_case_type_tree_view" model="ir.ui.view">
        <field name="name">hr.warning.case.type.tree</field>
        <field name="model">hr.warning.case.type</field>
        <field name="arch" type="xml">
            <tree string="Case Types" editable="top" js_class="warning_dashboard_list">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="warning_count" string="Incidents"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="hr_warning_case_type_form_view" model="ir.ui.view">
        <field name="name">hr.warning.case.type.form</field>
        <field name="model">hr.warning.case.type</field>
        <field name="arch" type="xml">
            <form string="Case Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_warnings"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-exclamation-triangle">
                            <field name="warning_count" widget="statinfo" string="Incidents"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="categories"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" colspan="2" nolabel="1" placeholder="Describe when this case type applies..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         KANBAN VIEW
    ════════════════════════════════════════════ -->
    <record id="hr_warning_case_type_kanban_view" model="ir.ui.view">
        <field name="name">hr.warning.case.type.kanban</field>
        <field name="model">hr.warning.case.type</field>
        <field name="arch" type="xml">
            <kanban default_group_by="categories"
                    group_create="true"
                    quick_create="true">
                <field name="name"/>
                <field name="code"/>
                <field name="categories"/>
                <field name="active"/>
                <!-- <field name="kanban_state"/> -->
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="measure-option" colspan="2">
                                    <div class="measure-option-title-little"><field name="name"/></div>
                                    <div class="measure-option-subtitle-little"><field name="description"/></div>
                                    <div class="measure-option-title-little"><field name="code"/></div>
                                    <field name="active" widget="boolean_toggle" 
                                    decoration-warning="description == ''"
                                    decoration-success="description != ''"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="action_hr_warning_case_type" model="ir.actions.act_window">
        <field name="name">Case Types</field>
        <field name="res_model">hr.warning.case.type</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No case types defined yet.
            </p>
            <p>Create case types such as Misconduct, Harassment, or Theft to classify incidents.</p>
        </field>
    </record>

</odoo>
