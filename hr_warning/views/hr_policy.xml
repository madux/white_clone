<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_warning_policy_tree_view" model="ir.ui.view">
        <field name="name">hr.warning.policy.tree</field>
        <field name="model">hr.warning.policy</field>
        <field name="arch" type="xml">
            <tree string="Policies" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="hr_warning_policy_srm_view" model="ir.ui.view">
        <field name="name">hr.warning.policy.form</field>
        <field name="model">hr.warning.policy</field>
        <field name="arch" type="xml">
            <form string="policy">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Describe when this policy applies..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_warning_policy" model="ir.actions.act_window">
        <field name="name">Policies</field>
        <field name="res_model">hr.warning.policy</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Policies defined yet.
            </p>
            <p>Create Policies such as Misconduct, Harassment, or Theft to classify incidents.</p>
        </field>
    </record>

</odoo>
