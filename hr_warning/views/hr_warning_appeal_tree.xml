<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════
         FORM VIEW
    ════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════
         TREE VIEW
    ════════════════════════════════════════════ -->
    
    <record id="ir_action_warning_appeal" model="ir.actions.server">
        <field name="name">Appeal*</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="hr_warning.model_hr_warning" />
        <field name="binding_model_id" ref="hr_warning.model_hr_warning" />
        <field name="state">code</field>
        <field name="groups_id" eval="[(6, 0, [
        ref('base.group_system'), 
        ref('hr.group_hr_manager'),
        ref('hr_warning.group_hr_warning_officer'),
        ref('hr_warning.group_hr_warning_manager'),
        ])]"/>
        <field name="code">action=model.sudo().action_appeal_case()</field>
    </record>

    <record id="ir_action_set_warning_appeal" model="ir.actions.server">
        <field name="name">Set to Appeal state*</field>
        <field name="type">ir.actions.server</field>
        <field name="model_id" ref="hr_warning.model_hr_warning" />
        <field name="binding_model_id" ref="hr_warning.model_hr_warning" />
        <field name="state">code</field>
        <field name="groups_id" eval="[(6, 0, [
        ref('base.group_system'), 
        ref('hr.group_hr_manager'),
        ref('hr_warning.group_hr_warning_officer'),
        ref('hr_warning.group_hr_warning_manager'),
        ])]"/>
        <field name="code">action=model.sudo().action_resolve()</field>
    </record>
    <record id="hr_warning_appeal_tree_view" model="ir.ui.view">
        <field name="name">hr.warning.appeal.tree</field>
        <field name="model">hr.warning</field>
        <field name="arch" type="xml">
            <tree string="Incidents Appeal" js_class="warning_dashboard_list"
                  decoration-warning="state == 'appeal'"
                  editable="top" create="true" delete="true">
                <field name="name" string="Reference" readonly="1"/>
                <field name="employee_id" string="Employee" widget="many2one_avatar_employee" readonly="1" options="{'no_open': true, 'no_create': true}"/>
                <field name="incident_type" string="Incident Type" readonly="1" options="{'no_open': true, 'no_create': true}"/>
                <field name="date_incident" optional="hide" string="Date" readonly="1"/>
                <field name="description" string="Description" optional="hide" readonly="1"/>
                <field name="appeal_description" string="Appeal Note" widget="text" required="1"/>
                <field name="appeal_officer_ids" widget="many2many_tags" readonly="0" required="1"/>
                <field name="appeal_date" readonly="0"/>
                <field name="appeal_state" readonly="1"/>
                <field name="location" optional="hide" readonly="1"/>
                <field name="stage_id" optional="hide" string="Stage" readonly="1" options="{'no_open': true, 'no_create': true}"/>
                <field name="priority" widget="priority" optional="hide" readonly="1"/>
                <field name="state" string="Status"
                       widget="badge" optional="hide"
                       decoration-warning="state == 'draft'"
                       decoration-info="state == 'under_investigation'"
                       decoration-primary="state == 'pending_approval'"
                       decoration-success="state == 'closed'"
                       decoration-danger="state == 'appeal'" readonly="1"/>
                <button name="action_move_review"
                    type="object"
                    string="Review"
                    class="oe_highlight fa fa-eye" invisible="appeal_state != 'appelled'"/>

                <button name="action_approve_resolution"
                    type="object" string="Resolve"
                    class="oe_highlight fa fa-file" invisible="appeal_state != 'review'"/>
                <button name="action_undo_resolution"
                    type="object" string="Undo"
                    class="oe_highlight fa fa-file" invisible="appeal_state != 'resolution'"/>
                <field name="action_menu"
                    widget="list_dropdown_actions"
                    string="Actions"/>
            </tree>
        </field>
    </record> 
    <!-- ═══════════════════════════════════════════
         ACTION
    ════════════════════════════════════════════ -->

    <record id="action_hr_warning_appeal" model="ir.actions.act_window">
        <field name="name">Incident Appeals</field>
        <field name="res_model">hr.warning</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'appeal')]</field>
        <field name="context">{'default_state':'appeal'}</field>
        <!-- <field name="search_view_id" ref="hr_warning_search_view"/> -->
        <field name="view_id" ref="hr_warning_appeal_tree_view"/>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Appeal recorded yet.
            </p>
            <p>Create a new incident to begin tracking employee conduct cases.</p>
        </field>
    </record>

    

</odoo>
