<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_warning_stage_tree_view" model="ir.ui.view">
        <field name="name">hr.warning.stage.tree</field>
        <field name="model">hr.warning.stage</field>
        <field name="arch" type="xml">
            <tree string="Stages" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="approver_ids" widget="many2many_tags"/>
                <field name="is_initial"/>
                <field name="is_closed"/>
                <field name="is_hearing"/>
                <field name="mail_template_id" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="hr_warning_stage_form_view" model="ir.ui.view">
        <field name="name">hr.warning.stage.form</field>
        <field name="model">hr.warning.stage</field>
        <field name="arch" type="xml">
            <form string="Incident Stage">
                <sheet>
                    <group>
                        <group string="Stage Details">
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="is_initial"/>
                            <!-- <field name="is_hearing"/> -->
                            <field name="is_closed"/>
                            <field name="fold"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Notifications">
                            <field name="approver_ids" required=""
                                   widget="many2many_tags"
                                   string="Approvers"
                                   help="These users receive an email when an incident enters this stage."/>
                            <field name="mail_template_id"
                                   string="Email Template"
                                   help="Override the default notification template for this stage."/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description"
                               nolabel="1"
                               placeholder="Describe what happens at this stage..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_warning_stage" model="ir.actions.act_window">
        <field name="name">Incident Stages</field>
        <field name="res_model">hr.warning.stage</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No stages configured yet.
            </p>
            <p>Add stages to define the incident processing pipeline and assign approvers to each step.</p>
        </field>
    </record>

</odoo>
