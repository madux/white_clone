<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         HTML PAGE served at /plan_view/page
         This is what gets rendered inside the iframe.
         Customize this freely — it's a normal web page.
    ═══════════════════════════════════════════════════════════════════ -->
    <template id="plan_page_template" name="Plan View Page">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <title>Plan View</title>
                <style>
                    * { box-sizing: border-box; margin: 0; padding: 0; }

                    body {
                        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                        background: #f8f9fa;
                        color: #212529;
                        padding: 24px;
                        min-height: 100vh;
                    }

                    .plan-header {
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        margin-bottom: 24px;
                        padding-bottom: 16px;
                        border-bottom: 1px solid #dee2e6;
                    }

                    .plan-header h1 {
                        font-size: 20px;
                        font-weight: 600;
                        color: #1a1a2e;
                    }

                    .plan-badge {
                        background: #017e84;
                        color: #fff;
                        font-size: 11px;
                        font-weight: 600;
                        padding: 3px 8px;
                        border-radius: 10px;
                        letter-spacing: 0.04em;
                        text-transform: uppercase;
                    }

                    /* ── Canvas area (replace with your actual plan/map/diagram) ── */
                    .plan-canvas {
                        background: #fff;
                        border: 1px solid #dee2e6;
                        border-radius: 8px;
                        min-height: 480px;
                        position: relative;
                        overflow: hidden;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                    }

                    .plan-canvas .grid-bg {
                        position: absolute;
                        inset: 0;
                        background-image:
                            linear-gradient(rgba(0,0,0,.04) 1px, transparent 1px),
                            linear-gradient(90deg, rgba(0,0,0,.04) 1px, transparent 1px);
                        background-size: 32px 32px;
                    }

                    .plan-canvas .placeholder-msg {
                        position: relative;
                        text-align: center;
                        color: #6c757d;
                    }

                    .plan-canvas .placeholder-msg svg {
                        display: block;
                        margin: 0 auto 12px;
                        opacity: .4;
                    }

                    .plan-canvas .placeholder-msg p {
                        font-size: 14px;
                    }

                    /* ── Info panel ── */
                    .plan-info {
                        margin-top: 16px;
                        display: flex;
                        gap: 12px;
                        flex-wrap: wrap;
                    }

                    .info-card {
                        background: #fff;
                        border: 1px solid #dee2e6;
                        border-radius: 8px;
                        padding: 14px 18px;
                        flex: 1;
                        min-width: 180px;
                    }

                    .info-card .label {
                        font-size: 11px;
                        font-weight: 600;
                        text-transform: uppercase;
                        letter-spacing: .06em;
                        color: #868e96;
                        margin-bottom: 4px;
                    }

                    .info-card .value {
                        font-size: 15px;
                        font-weight: 500;
                        color: #212529;
                    }

                    /* ── Live records table ── */
                    .records-section {
                        margin-top: 24px;
                    }

                    .records-section h2 {
                        font-size: 14px;
                        font-weight: 600;
                        margin-bottom: 10px;
                        color: #495057;
                    }

                    table {
                        width: 100%;
                        border-collapse: collapse;
                        font-size: 13px;
                        background: #fff;
                        border: 1px solid #dee2e6;
                        border-radius: 8px;
                        overflow: hidden;
                    }

                    thead th {
                        background: #f1f3f5;
                        padding: 10px 14px;
                        text-align: left;
                        font-weight: 600;
                        color: #495057;
                        border-bottom: 1px solid #dee2e6;
                    }

                    tbody td {
                        padding: 9px 14px;
                        border-bottom: 1px solid #f1f3f5;
                        color: #495057;
                    }

                    tbody tr:last-child td { border-bottom: none; }
                    tbody tr:hover td { background: #f8f9fa; }

                    #loading { color: #6c757d; font-size: 13px; padding: 12px 14px; }
                </style>
            </head>
            <body>

                <div class="plan-header">
                    <h1>Plan View</h1>
                    <span class="plan-badge">Live</span>
                    <t t-if="model">
                        <span style="font-size:13px;color:#6c757d;">
                            Model: <strong t-out="model"/>
                            <t t-if="res_id"> · Record #<strong t-out="res_id"/></t>
                        </span>
                    </t>
                </div>

                <!-- ── Your main canvas / map / diagram goes here ── -->
                <div class="plan-canvas">
                    <div class="grid-bg"/>
                    <div class="placeholder-msg">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <path d="M3 9h18M9 21V9"/>
                        </svg>
                        <p>Your plan canvas renders here.<br/>Replace this with a floor plan, map, diagram, or any HTML content.</p>
                    </div>
                </div>

                <!-- ── Context passed in from Odoo ── -->
                <div class="plan-info">
                    <div class="info-card">
                        <div class="label">Model</div>
                        <div class="value"><t t-out="model or '—'"/></div>
                    </div>
                    <div class="info-card">
                        <div class="label">Record</div>
                        <div class="value"><t t-out="record_data.get('name') or res_id or '—'"/></div>
                    </div>
                    <div class="info-card">
                        <div class="label">Action</div>
                        <div class="value"><t t-out="action_id or '—'"/></div>
                    </div>
                </div>

                <!-- ── Live data fetched from Odoo JSON endpoint ── -->
                <div class="records-section" id="records-section" style="display:none">
                    <h2>Live records from Odoo</h2>
                    <table>
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                            </tr>
                        </thead>
                        <tbody id="records-body">
                            <tr><td colspan="2" id="loading">Loading…</td></tr>
                        </tbody>
                    </table>
                </div>

                <script>
                    // ── Fetch live Odoo data from the JSON endpoint ──────────────
                    // This runs inside the iframe but the request goes to the same
                    // Odoo origin, so the session cookie is shared automatically.
                    const model = '<t t-out="model or &quot;&quot;"/>';

                    if (model) {
                        document.getElementById('records-section').style.display = 'block';

                        fetch('/plan_view/data', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                jsonrpc: '2.0',
                                method: 'call',
                                params: {
                                    model: model,
                                    domain: [],
                                    fields: ['id', 'name'],
                                }
                            })
                        })
                        .then(r => r.json())
                        .then(data => {
                            const records = data.result?.records || [];
                            const tbody = document.getElementById('records-body');
                            if (!records.length) {
                                tbody.innerHTML = '<tr><td colspan="2" style="color:#6c757d;padding:12px 14px">No records found.</td></tr>';
                                return;
                            }
                            tbody.innerHTML = records.map(r =>
                                `<tr><td>${r.id}</td><td>${r.name || '—'}</td></tr>`
                            ).join('');
                        })
                        .catch(() => {
                            document.getElementById('loading').textContent = 'Could not load records.';
                        });
                    }

                    // ── Communicate with the parent Odoo window ───────────────────
                    // Use postMessage to send events up to the OWL component.
                    // Example: clicking a plan element opens the Odoo record.
                    function openOdooRecord(model, id) {
                        window.parent.postMessage(
                            { type: 'plan_view:open_record', model, id },
                            window.location.origin
                        );
                    }
                </script>

            </body>
        </html>
    </template>

</odoo>
